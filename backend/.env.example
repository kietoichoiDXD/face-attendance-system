# Google Cloud project setup
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1

# Bucket names
STUDENT_FACES_BUCKET=your-student-faces-bucket
CLASS_UPLOADS_BUCKET=your-class-uploads-bucket

# Firestore collections
STUDENTS_COLLECTION=students
ATTENDANCE_COLLECTION=attendance
CLASSES_COLLECTION=classes

# Vision and matching
VISION_PROVIDER=google
MATCH_SIMILARITY_THRESHOLD=0.88

# Option A: use ADC by setting GOOGLE_APPLICATION_CREDENTIALS externally
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option B: provide service account JSON payload (do not commit real values)
GCP_SERVICE_ACCOUNT_JSON=
GCP_SERVICE_ACCOUNT_JSON_B64=
